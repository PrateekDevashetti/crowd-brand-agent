# Server
PORT=3000
BASE_URL=http://localhost:3000

# Infra
# Ports 5433/6380 match docker-compose.yml (kept clear of any local Postgres/Redis)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/brandlayer
REDIS_URL=redis://127.0.0.1:6380

# Auth — any request with this key maps to the seeded dev user
DEV_API_KEY=dev-secret

# Image provider — auto-selects: gemini → openai → mock (solid-color placeholders)
# Or force one with IMAGE_PROVIDER=gemini|openai|mock
GEMINI_API_KEY=
OPENAI_API_KEY=
IMAGE_PROVIDER=
# OpenAI image model: gpt-image-1-mini (cheap) | gpt-image-1.5 | gpt-image-2 (best)
OPENAI_IMAGE_MODEL=gpt-image-1-mini

# Brand extraction brain (optional) — when set, Claude distills brand profiles
# instead of the image provider's LLM. Best quality for the core step.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Auth (Clerk) — leave empty for dev-mode login (DEV_API_KEY)
# Create a free app at https://dashboard.clerk.com → API Keys
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Storage
STORAGE_DIR=./storage
